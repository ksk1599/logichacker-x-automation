# =====================================================
# 로직해커 엑스 멀티에이전트 시스템 - 환경변수 템플릿
# =====================================================
# 사용법: 이 파일을 .env로 복사한 뒤 실제 값으로 채우세요.
# .env 파일은 절대 git에 커밋하지 마세요. (.gitignore 처리됨)

# ---------- Supabase ----------
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxx

# ---------- Threads API ----------
# 장기 토큰: 60일 유효. 58일째에 Scheduler가 갱신 알림 발송.
THREADS_ACCESS_TOKEN=THAAxxxxx
THREADS_USER_ID=1234567890123456
THREADS_APP_ID=1234567890123456
THREADS_APP_SECRET=xxxxx
THREADS_TOKEN_ISSUED_AT=2026-04-09

# ---------- Discord ----------
# 검수용 (QA 합격 글이 여기로 발송됨)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
# 알림용 (Supervisor 경고, 에러 로그)
DISCORD_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# ---------- n8n ----------
N8N_BASE_URL=https://n8n-production-9b1b.up.railway.app
N8N_API_KEY=xxxxx

# ---------- Anthropic (선택) ----------
# 에이전트가 별도로 Claude API 호출이 필요할 때
ANTHROPIC_API_KEY=sk-ant-xxxxx
